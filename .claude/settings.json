{
  "permissions": {
    "allow": [
      "Bash(make:*)",
      "Bash(mix:*)",
      "Bash(zig:*)",
      "Bash(explicit:*)",
      "Bash(gemini:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git status:*)",
      "Bash(git show:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "explicit hooks claude check-fixme",
            "type": "command"
          }
        ],
        "matcher": "^(Edit|Write)$"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "make debug && devenv shell -- bash -c 'cd server && mix test && INCLUDE_ERTS=false mix release --overwrite'",
            "type": "command"
          }
        ]
      }
    ]
  }
}
